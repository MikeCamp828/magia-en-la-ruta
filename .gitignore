
---

## `.gitignore`

```gitignore
# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so
.Python
venv/
env/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt

# ==========================
# FastAPI / Backend
# ==========================
*.db
*.sqlite3
.env
.env.local
.env.development
.env.production

# ==========================
# Node / React
# ==========================
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# Vite
# ==========================
.vite/

# ==========================
# IDEs
# ==========================
.vscode/
.idea/
*.swp
*.swo

# ==========================
# Sistema operativo
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Logs
# ==========================
logs/
*.log

# ==========================
# Docker
# ==========================
docker-data/